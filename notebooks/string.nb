Cell[BoxData[{
 RowBox[{"Simplify", "[", 
  RowBox[{
   FractionBox["2", "L"], 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{
        FractionBox["\[Pi]", "L"], "n", " ", "x"}], "]"}], 
      RowBox[{"Sin", "[", 
       RowBox[{
        FractionBox["\[Pi]", "L"], "m", " ", "x"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "L"}], "}"}]}], "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"FullSimplify", "[", 
  RowBox[{"%", ",", 
   RowBox[{
    RowBox[{"m", "\[Element]", "Integers"}], "&&", 
    RowBox[{"n", "\[Element]", "Integers"}]}]}], "]"}]}], "Input",
