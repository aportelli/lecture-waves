Cell[BoxData[{
 RowBox[{
  RowBox[{"u", "[", 
   RowBox[{"t_", ",", "x_", ",", "c_", ",", "f_"}], "]"}], ":=", 
  FractionBox[
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", "+", 
      RowBox[{"c", " ", "t"}]}], "]"}], "+", 
    RowBox[{"f", "[", 
     RowBox[{"x", "-", 
      RowBox[{"c", " ", "t"}]}], "]"}]}], "2"]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"per", "[", 
   RowBox[{"f_", ",", "u_", ",", "L_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "um", "}"}], ",", 
    RowBox[{
     RowBox[{"um", "=", 
      RowBox[{"Mod", "[", 
       RowBox[{"u", ",", 
        RowBox[{"2", "L"}]}], "]"}]}], ";", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"um", "<", "L"}], ",", 
       RowBox[{"f", "[", "um", "]"}], ",", 
       RowBox[{"-", 
        RowBox[{"f", "[", 
         RowBox[{
          RowBox[{"2", "L"}], "-", "um"}], "]"}]}]}], "]"}]}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.940940248633873*^9, 3.940940283070479*^9}, {
  3.940940336618787*^9, 3.940940370385376*^9}, {3.945530112101486*^9, 
  3.945530112309492*^9}},
