Cell[BoxData[
 FractionBox[
  RowBox[{
   FractionBox[
    RowBox[{"Sin", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"m", "-", "n"}], ")"}], " ", "\[Pi]"}], "]"}], 
    RowBox[{"m", "-", "n"}]], "-", 
   FractionBox[
    RowBox[{"Sin", "[", 
     RowBox[{
      RowBox[{"(", 
